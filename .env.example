# Reviewer 环境变量样例（汇总清单）
# 后端实际从 backend/.env 读取；本文件与 backend/.env.example 保持一致，便于在项目根目录快速查阅。
# 复制为 backend/.env 后按需填写。带「必需」的三项缺失/为空时后端将 fail-fast 拒绝启动。

# ---- LLM Provider（必需）----
# LLM_BASE_URL：LLM_Provider 基础地址（OpenAI 兼容），例如 https://api.openai.com/v1
LLM_BASE_URL=
# LLM_API_KEY：LLM_Provider API 密钥，用于向 LLM 服务鉴权
LLM_API_KEY=
# LLM_MODEL：LLM_Provider 模型名称，例如 gpt-4o-mini
LLM_MODEL=

# ---- GitHub（可选）----
# GITHUB_TOKEN：GitHub 访问令牌；配置后提升 GitHub API 速率限制额度，
# 缺失时以匿名方式访问，额度较低，可能影响大仓库抓取
GITHUB_TOKEN=

# ---- Redis（队列 + Pub/Sub + 会话状态）----
# REDIS_URL：Redis 连接地址，用于任务队列、事件总线与会话状态
REDIS_URL=redis://localhost:6379/0

# ---- PostgreSQL（评估历史 + 模型配置持久化）----
# DATABASE_URL：asyncpg 驱动连接串；一体化部署时 compose 会覆盖为 postgres 服务名
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reviewer

# ---- 并发与 Agent 控制 ----
# REVIEW_MAX_CONCURRENT：单个 Worker 进程最大并发评估数（默认 4）
REVIEW_MAX_CONCURRENT=4
# AGENT_MAX_ITERATIONS：单个 Agent ReAct 循环最大轮数（默认 8，范围 1–20）
AGENT_MAX_ITERATIONS=8
